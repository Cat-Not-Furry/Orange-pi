# Copiar a .env y cargar según entorno. No versionar .env

# --- Sesión y recordings (raíz del repo por defecto) ---
# SESSION_ID=                      # opcional; si vacío, fecha-hora en Pi
# RECORDINGS_DIR=/ruta/a/repo/recordings
ANALYSIS_SUBDIR=analysis
VIDEO_SOURCE_SUBDIR=video_source
SAVE_LOCAL_ANALYSIS=1
SAVE_HOST_FRAMES=1
HOST_SAVE_JPEG_QUALITY=75

# 1 = subir JPEG de captura (Pi + UDP) hacia ANALYSIS_JPEG_QUALITY
ORANGE_ANALYSIS_MAX=0
ANALYSIS_JPEG_QUALITY=98

# --- Emisor UDP (Orange Pi) ---
UDP_DEST_IP=
UDP_HOST=
UDP_PORT=5555
UDP_PACKET_SIZE=1400
UDP_RETRANSMIT=0

CAMERA_INDICES=0,1,2
FRAME_WIDTH=640
FRAME_HEIGHT=360
FPS=15
JPEG_QUALITY=92
JPEG_LUMA_QUALITY=24
JPEG_CHROMA_QUALITY=30
ROTATE=0
MAX_QUEUE_SIZE=300

# 1 = MJPEG en el driver USB (no es archivo MP4). 0 = formato por defecto del dispositivo
CAMERA_USE_MJPEG=1

# Colas en el emisor Pi: envío UDP y guardado en analysis/ (no bloquean la captura)
IMG_UDP_SEND_QUEUE_SIZE=4
IMG_UDP_QUEUE_DROP_OLDEST=1
DISK_SAVE_QUEUE_SIZE=8
SAVE_LOCAL_EVERY_N=1

IMG_UDP_QUALITY_MAX=0
IMG_UDP_QUALITY_SUPERIOR=0

GPS_PORT=/dev/ttyS3
GPS_BAUD=9600
GPS_TIMEOUT=1

MAX_CPU_PERCENT=70
MAX_MEMORY_PERCENT=80

# --- Receptor (laptop) ---
UDP_BIND_HOST=0.0.0.0

# --- HTTP recorder.py (opcional) ---
LOG_FILE=stream.log
HTTPS_PORT=5000
SSL_ADHOC=0
SSL_CRT_FILE=
SSL_KEY_FILE=
