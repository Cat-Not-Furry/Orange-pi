# Copiar a .env y ajustar valores. No versionar .env

# Dispositivo (Orange Pi, Raspberry Pi, etc.)
CAMERA_INDICES=0,1,2
LOG_FILE=stream.log
PAGE_TITLE=Streaming de video

# Streaming
FRAME_WIDTH=1280
FRAME_HEIGHT=720
FPS=30
JPEG_QUALITY=80
METRICS_LOG_INTERVAL=10

# HTTPS
# Ruta al certificado (PEM)
SSL_CRT_FILE=
# Ruta a la clave privada (PEM)
SSL_KEY_FILE=
# 1 = certificado adhoc (solo desarrollo, requiere pyopenssl)
SSL_ADHOC=0
# Puerto cuando HTTPS está activo
HTTPS_PORT=5000

# Estabilización y alcance
# Frames en buffer (0 = desactivado, 5-10 para red inestable)
FRAME_BUFFER_SIZE=0
# 1 = reduce FPS y calidad para redes inestables
UNSTABLE_NETWORK_MODE=0
# 1 = 640x360, 15fps, JPEG 60 (alcance 80m+)
LONG_RANGE_MODE=0
# 1 = máxima calidad (1920x1080, 60fps, JPEG 95)
MAX_QUALITY_MODE=0
# 1 = 1280x720 a 60 fps estable
FPS_60_MODE=0
# 1 = más CPU (resize, blur, JPEG 90+)
CPU_INTENSIVE_MODE=0

# Recursos dinámicos (ajusta FPS/calidad para no saturar)
DYNAMIC_RESOURCES=0
CPU_TARGET_PCT=70
RAM_TARGET_PCT=70
ADAPT_INTERVAL_SEC=5
TARGET_FPS=60
RESOURCE_INITIAL_LEVEL=4

# TCP (Orange Pi -> Laptop)
TCP_HOST=
TCP_PORT=5555
GPS_PORT=/dev/ttyS3
GPS_BAUD=9600
TCP_QUALITY_MAX=0
TCP_QUALITY_SUPERIOR=0
TCP_QUALITY_NORMAL=0

# UDP (Orange Pi -> Laptop; en laptop: python receiver.py udp)
UDP_HOST=
UDP_PORT=5555
UDP_PACKET_SIZE=1400
UDP_QUALITY_MAX=0
UDP_QUALITY_SUPERIOR=0
UDP_QUALITY_NORMAL=0
